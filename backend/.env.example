# BJJBFIT - Environment Variables Configuration
# Copy this file to .env and fill in the values

# SECURITY
DJANGO_SECRET_KEY=generate-a-secure-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE
DB_NAME=bjjfit
